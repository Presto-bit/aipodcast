# Python（本仓库推荐 .venv-ai-native，见 Makefile dev-install）
.venv-ai-native/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
# Next.js 应用源码（勿与 Python venv 的 lib/ 混淆；上面 lib/ 会误伤此目录）
!apps/web/lib/
!apps/web/lib/**
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# legacy_backend：上传与生成物（与 legacy_backend/config 中 OUTPUT_DIR / UPLOAD_DIR 一致）
legacy_backend/uploads/*
legacy_backend/outputs/*
legacy_backend/data/*
!legacy_backend/uploads/.gitkeep
!legacy_backend/outputs/.gitkeep
!legacy_backend/data/.gitkeep

##密码文件
secrets/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# 日志
*.log

# 临时文件
*.tmp
*.temp
.cache/

# 离线构建：由 scripts/package-offline-bundle.sh 下载的 wheel，勿提交
docker/offline-pip-wheels/*
!docker/offline-pip-wheels/.gitkeep

# 环境变量
.env
.env.local
.env.ai-native
deploy/deploy.env

# 运行时中间文件
legacy_backend/outputs/tmp/

# Node.js / Next.js
node_modules/
apps/web/node_modules/
apps/web/.next/
apps/web/playwright-report/
apps/web/test-results/
apps/web/blob-report/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# /etc/default/aipodcast 示例（给 systemd 的 EnvironmentFile 使用）
# 使用方式：
#   sudo cp deploy/aipodcast.env.example /etc/default/aipodcast
#   sudo nano /etc/default/aipodcast
#   sudo chmod 600 /etc/default/aipodcast

# ========== 认证开关 ==========
FYV_AUTH_ENABLED=1
FYV_REQUIRE_INVITE=0
FYV_ADMIN_INVITE_CODE=change-this-invite-code
FYV_AUTH_DEBUG_RESET_CODE=0

# ========== 邮件（注册验证码 / 重置密码；由编排器读取，须能连 SMTP）==========
# 重置密码：仅向「库中已存在且 email_verified_at 非空」的账号发信；须配置 FYV_SMTP_HOST 与 FYV_AUTH_VERIFY_BASE_URL
# 生产须保持关闭：日志发码、跳过邮箱验证（FYV_PRODUCTION=1 时编排器启动会校验）
FYV_AUTH_EMAIL_LOG_TOKEN=0
FYV_AUTH_EMAIL_AUTOVERIFY=0
# FYV_AUTH_VERIFY_BASE_URL=https://www.prestoai.cn
# COOKIE_DOMAIN=.prestoai.cn
# FYV_AUTH_SESSION_BACKEND=redis
# FYV_SMTP_VERIFY_SUBJECT=[Presto] 验证你的邮箱
# FYV_SMTP_RESET_SUBJECT=[Presto] 找回密码
# FYV_SMTP_REGISTER_OTP_SUBJECT=[Presto] 注册验证码
# FYV_SMTP_HOST=smtp.example.com
# FYV_SMTP_PORT=587
# FYV_SMTP_USER=noreply@example.com
# FYV_SMTP_PASSWORD=
# FYV_SMTP_FROM=noreply@example.com
# FYV_SMTP_REGISTER_OTP_SUBJECT=注册验证码
# FYV_SMTP_RESET_SUBJECT=重置密码

# ========== 鉴权限流/会话（可按需调整） ==========
# 注：如代码中未读取这些变量，可忽略；保留是为后续参数化预留
# FYV_SESSION_TTL_SEC=604800
# FYV_FEATURE_UNLOCK_TTL_SEC=28800

# ========== 运行时目录（可选） ==========
# 若需把业务数据放到独立磁盘，可设置以下目录（绝对路径推荐）
# FYV_RUNTIME_DIR=/opt/minimax_aipodcast/legacy_backend
# FYV_DATA_DIR=/var/lib/minimax_aipodcast/data
# FYV_UPLOAD_DIR=/var/lib/minimax_aipodcast/uploads
# FYV_OUTPUT_DIR=/var/lib/minimax_aipodcast/outputs

# ========== RAG / Embedding（OpenAI 兼容 /embeddings；见 app/fyv_shared/embedding_provider.py）==========
RAG_EMBEDDING_PROVIDER=api
RAG_EMBEDDING_API_URL=https://api.minimaxi.com/v1/embeddings
RAG_EMBEDDING_MODEL=embo-01
# 可选：与 MINIMAX_API_KEY 分离的向量 Key
# RAG_EMBEDDING_API_KEY=
# RAG_EMBEDDING_TIMEOUT_SEC=25
# 主端点失败后是否再试 MiniMax 默认 embedding（默认 1；0=关闭）
# RAG_EMBEDDING_MINIMAX_FALLBACK=1
# RAG_EMBEDDING_MINIMAX_FALLBACK_MODEL=embo-01
# 非 MiniMax 的 OpenAI 兼容向量（先于 RAG_EMBEDDING_API_URL 尝试；DeepSeek 官方无 embedding）
# RAG_EMBEDDING_OPENAI_COMPAT_BASE=https://api.openai.com/v1
# RAG_EMBEDDING_OPENAI_COMPAT_API_KEY=
# RAG_EMBEDDING_OPENAI_COMPAT_MODEL=text-embedding-3-small
# local：需镜像内 sentence-transformers；hash：仅调试
# RAG_EMBEDDING_LOCAL_MODEL=BAAI/bge-small-zh-v1.5

# ========== MiniMax API Key ==========
# 强烈建议在生产环境通过环境变量注入，避免写入仓库文件
# 请替换为你自己的 Key
MINIMAX_API_KEY=replace-with-your-minimax-api-key
# 可选：覆盖 app/fyv_shared/config.py 内默认模型名（与 .env.ai-native 中变量名一致）
# MINIMAX_TEXT_MODEL=MiniMax-M2-Preview
# MINIMAX_TTS_MODEL=speech-2.8-turbo
# MINIMAX_VOICE_CLONE_MODEL=speech-02-turbo
# MINIMAX_IMAGE_MODEL=image-01-live
# 封面/配图：MiniMax 仅允许 style_type=漫画|元气|中世纪|水彩（勿用「插画」）。可选：MINIMAX_IMAGE_STYLE_TYPE、MINIMAX_IMAGE_STYLE_WEIGHT
# MINIMAX_IMAGE_STYLE_TYPE=元气

# ========== AI Provider 路由 ==========
# 文本 minimax | deepseek | qwen；不写 TEXT_PROVIDER 时默认 deepseek（失败回退 MiniMax）；仅文本走 MiniMax 时设置 TEXT_PROVIDER=minimax
TTS_PROVIDER=minimax
IMAGE_PROVIDER=minimax
VOICE_CLONE_PROVIDER=minimax
# AI 润色后是否对文案跑 sanitize_for_tts（默认关闭）；需恢复旧行为时取消注释：
# TTS_SANITIZE_AFTER_POLISH=1

# DeepSeek 文本（TEXT_PROVIDER=deepseek 时必填）
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_TEXT_MODEL=deepseek-chat

# 通义千问文本（TEXT_PROVIDER=qwen）
# QWEN_API_KEY=
# QWEN_BASE_URL=
# QWEN_TEXT_MODEL=qwen-plus

# 千问图像（IMAGE_PROVIDER=qwen）
# QWEN_IMAGE_URL=
# QWEN_IMAGE_MODEL=wanx-v1

# 豆包 TTS / 克隆（TTS_PROVIDER=doubao 等）
# DOUBAO_API_KEY=
# DOUBAO_TTS_URL=
# DOUBAO_TTS_MODEL=doubao-tts
# DOUBAO_VOICE_CLONE_URL=
# DOUBAO_VOICE_CLONE_MODEL=doubao-voice-clone

# ========== 笔记播客：分层摘要+勾选内向量（app/note_rag_service.py）==========
# NOTE_LAYERED_RAG=1
# NOTE_RAG_MAX_CHUNKS_PER_NOTE=160
# 向量精排前候选块硬上限（多笔记勾选时控 CPU/内存，默认 2500）
# NOTE_RAG_VECTOR_CANDIDATE_CAP=2500

# ========== RAG 切块 / hybrid 权重（app/rag_core.py）==========
# RAG_CHUNK_CHARS=1100
# RAG_CHUNK_OVERLAP=90
# RAG_HYBRID_VECTOR_WEIGHT=0.55
# RAG_HYBRID_KEYWORD_WEIGHT=0.45

# ========== 图片 / 封面 ==========
# 播客封面与配图走 MiniMax 图像 API（app.fyv_shared.minimax_client.generate_cover_image），无需单独配置阿里云
IMAGE_PROVIDER_FALLBACK=minimax

# ========== AI润色（进 TTS 前文本模型）==========
# 设为 0 则全站关闭（任务内 ai_polish 与 /polish_tts_text 均不生效）；默认 1
# 业务规则：仅订阅 plan=max 的用户可开启；关闭本开关后所有人都不可用
# AI_POLISH_FEATURE_ENABLED=1

# ========== Redis / RQ（播客 podcast_generate 走 media 队列；文稿 script_draft 走 ai）==========
# REDIS_URL 须与 orchestrator、media-worker、ai-worker 完全一致，否则任务会长期停留在 queued。
# 运维自检：curl -sS http://127.0.0.1:8008/health（看 queues、rq_workers、queue_alerts；编排器需可达）。
# FYV_PRODUCTION=1 时默认关闭编排器内嵌 media 消费者，须单独部署 workers/media-worker，或小型环境显式 ORCHESTRATOR_EMBED_RQ_MEDIA_WORKER=1。详见仓库根 .env.ai-native.example 同段说明。

# ========== 支付与回调（生产若用 systemd EnvironmentFile，请与 .env.ai-native 对齐）==========
# PAYMENT_WEBHOOK_SECRET=  # JSON 类支付回调 HMAC；勿用于生产留空（见 DEPLOYMENT.md）
# ---------- 支付宝真实收款（编排器；须与开放平台异步通知地址一致）----------
# ALIPAY_PAY_ENABLED=1
# ALIPAY_SANDBOX=0
# ALIPAY_APP_ID=
# ALIPAY_APP_PRIVATE_KEY_PATH=/var/lib/aipodcast/secrets/app_private_key.pem
# ALIPAY_PUBLIC_KEY_PATH=/var/lib/aipodcast/secrets/alipay_public_key.pem
# ALIPAY_NOTIFY_URL=https://www.prestoai.cn/api/webhooks/alipay
# ALIPAY_RETURN_URL=https://www.prestoai.cn/subscription
# 变量说明与本地路径示例见仓库根 .env.ai-native.example；拓扑见 DEPLOYMENT.md「支付回调」。


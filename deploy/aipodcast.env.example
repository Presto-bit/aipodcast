# /etc/default/aipodcast 示例（给 systemd 的 EnvironmentFile 使用）
# 使用方式：
#   sudo cp deploy/aipodcast.env.example /etc/default/aipodcast
#   sudo nano /etc/default/aipodcast
#   sudo chmod 600 /etc/default/aipodcast

# ========== 认证开关 ==========
FYV_AUTH_ENABLED=1
FYV_REQUIRE_INVITE=0
FYV_ADMIN_INVITE_CODE=change-this-invite-code
FYV_AUTH_DEBUG_RESET_CODE=0

# ========== 鉴权限流/会话（可按需调整） ==========
# 注：如代码中未读取这些变量，可忽略；保留是为后续参数化预留
# FYV_SESSION_TTL_SEC=604800
# FYV_FEATURE_UNLOCK_TTL_SEC=28800

# ========== 运行时目录（可选） ==========
# 若需把业务数据放到独立磁盘，可设置以下目录（绝对路径推荐）
# FYV_RUNTIME_DIR=/opt/minimax_aipodcast/legacy_backend
# FYV_DATA_DIR=/var/lib/minimax_aipodcast/data
# FYV_UPLOAD_DIR=/var/lib/minimax_aipodcast/uploads
# FYV_OUTPUT_DIR=/var/lib/minimax_aipodcast/outputs

# ========== RAG / Embedding ==========
RAG_EMBEDDING_PROVIDER=api
RAG_EMBEDDING_API_URL=https://api.minimaxi.com/v1/embeddings
RAG_EMBEDDING_MODEL=embo-01

# ========== MiniMax API Key ==========
# 强烈建议在生产环境通过环境变量注入，避免写入仓库文件
# 请替换为你自己的 Key
MINIMAX_API_KEY=replace-with-your-minimax-api-key
# 可选：覆盖 app/fyv_shared/config.py 内默认模型名（与 .env.ai-native 中变量名一致）
# MINIMAX_TEXT_MODEL=MiniMax-M2-Preview
# MINIMAX_TTS_MODEL=speech-2.5-hd-preview
# MINIMAX_VOICE_CLONE_MODEL=speech-02-turbo
# MINIMAX_IMAGE_MODEL=image-01-live

# ========== AI Provider 路由（A 阶段） ==========
# 当前版本默认仅实现 minimax；若设置为其它值会静默回退 minimax（不影响现有功能）
TEXT_PROVIDER=minimax
TTS_PROVIDER=minimax
# AI 润色后是否对文案跑 sanitize_for_tts（默认关闭）；需恢复旧行为时取消注释：
# TTS_SANITIZE_AFTER_POLISH=1
IMAGE_PROVIDER=minimax
VOICE_CLONE_PROVIDER=minimax

# 以下为后续接入其它厂商预留（当前不生效）
# 文本（DeepSeek / 千问）
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_TEXT_MODEL=deepseek-chat
# QWEN_API_KEY=
# QWEN_BASE_URL=
# QWEN_TEXT_MODEL=qwen-plus
#
# 图像（千问）
# QWEN_IMAGE_URL=
# QWEN_IMAGE_MODEL=wanx-v1
#
# 音频（豆包）
# DOUBAO_API_KEY=
# DOUBAO_TTS_URL=
# DOUBAO_TTS_MODEL=doubao-tts
# DOUBAO_VOICE_CLONE_URL=
# DOUBAO_VOICE_CLONE_MODEL=doubao-voice-clone

# ========== 图片 / 封面 ==========
# 播客封面与配图走 MiniMax 图像 API（app.fyv_shared.minimax_client.generate_cover_image），无需单独配置阿里云
IMAGE_PROVIDER_FALLBACK=minimax

# ========== AI润色（进 TTS 前文本模型）==========
# 设为 0 则全站关闭（任务内 ai_polish 与 /polish_tts_text 均不生效）；默认 1
# 业务规则：仅订阅 plan=max 的用户可开启；关闭本开关后所有人都不可用
# AI_POLISH_FEATURE_ENABLED=1


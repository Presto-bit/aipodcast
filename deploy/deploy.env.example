# 复制为 deploy/deploy.env 后按实际情况修改（deploy.env 勿提交仓库）
# cp deploy/deploy.env.example deploy/deploy.env

APP_USER=ubuntu
DEPLOY_ROOT=/opt/minimax_aipodcast

# 1=安装 apt 依赖（docker.io 等），0=你已装好 Docker
INSTALL_APT=1

# 1=部署前 git pull
GIT_PULL=1

# 运行时业务环境变量（包含 MINIMAX_API_KEY 等）推荐配置在项目根目录 .env.ai-native。
# 若你使用 systemd + EnvironmentFile 方式启动，再改用 /etc/default/aipodcast（参考 deploy/aipodcast.env.example）。

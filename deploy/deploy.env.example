# 复制为 deploy/deploy.env 后按实际情况修改（deploy.env 勿提交仓库）
# cp deploy/deploy.env.example deploy/deploy.env

APP_USER=ubuntu
SERVER_NAME=你的公网IP或域名
DEPLOY_ROOT=/opt/minimax_aipodcast

# 1=安装 apt 依赖（nginx、nodejs、ffmpeg 等），0=你已装好
INSTALL_APT=1

# 1=部署前 git pull
GIT_PULL=1

# NodeSource 主版本
NODE_MAJOR=20

# 可选：后端 systemd 环境变量文件（示例：/etc/default/aipodcast）
# BACKEND_ENV_FILE=/etc/default/aipodcast

# 可选：显式指定 Python，适用于阿里云自装 Python
PYTHON_BIN=/usr/local/bin/python3.12

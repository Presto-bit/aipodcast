# 本机「热重载开发」：仅 docker compose 起 postgres/redis/minio 时，保持 DB/Redis/MinIO 指向 127.0.0.1（见 Makefile dev-infra）
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=aipodcast
DB_USER=aipodcast
DB_PASSWORD=aipodcast

REDIS_URL=redis://127.0.0.1:6379/0

OBJECT_ENDPOINT=http://127.0.0.1:9000
OBJECT_REGION=us-east-1
OBJECT_ACCESS_KEY=minioadmin
OBJECT_SECRET_KEY=minioadmin
OBJECT_BUCKET=aipodcast-artifacts
OBJECT_FORCE_PATH_STYLE=1

ORCHESTRATOR_PORT=8008
ORCHESTRATOR_API_TOKEN=local-dev-token
INTERNAL_SIGNING_SECRET=local-internal-secret

# Next.js BFF（apps/web）：NODE_ENV=production 且 `next start` 时 instrumentation 会强校验上述密钥（≥32 字符且非示例值）。
# 图片代理 /api/image-proxy：默认须登录（同源 Cookie）；可选仅允许部分 CDN 域名：
# IMAGE_PROXY_HOST_SUFFIXES=s3.amazonaws.com,cloudfront.net,storage.googleapis.com
# 本地未登录调试封面代理（勿用于生产）：IMAGE_PROXY_ALLOW_UNAUTHENTICATED=1

# 生产建议 1：启动期对象存储 / DDL 兜底任一失败则退出（见 DEPLOYMENT.md）
# ORCHESTRATOR_STRICT_SCHEMA=1

# 媒体队列：非 podcast_generate/podcast 的任务默认占位成功；生产可设为 1 拒绝假成功
# MEDIA_WORKER_FAIL_ON_NON_PODCAST=1

# 运行时文件目录（可选）：用于拆分持久数据 / 上传源文件 / 生成产物
# FYV_RUNTIME_DIR=legacy_backend
# FYV_DATA_DIR=legacy_backend/data
# FYV_UPLOAD_DIR=legacy_backend/uploads
# FYV_OUTPUT_DIR=legacy_backend/outputs
# FYV_AUTH_SESSION_BACKEND=redis
# 推荐生产：PG 为单一事实源（关闭 JSON 双写、JSON 仅只读镜像）；等价于 DUAL_WRITE=0 + JSON_BACKUP_READONLY=1
# FYV_AUTH_UNIFIED_PG=1
# FYV_AUTH_PG_PRIMARY=1
# FYV_AUTH_DUAL_WRITE=0
# FYV_AUTH_JSON_BACKUP_READONLY=1
# 注册邀请码：默认不要求；设为 1 时须传 invite_code 且等于 FYV_ADMIN_INVITE_CODE（Web 注册无输入框，需 API/脚本带码）
# FYV_REQUIRE_INVITE=0
# FYV_ADMIN_INVITE_CODE=fym-admin-2025
# 表结构以 infra/postgres/init + make migrate-db 为准；生产已迁移后可关运行时 DDL 兜底
# FYV_AUTH_RUNTIME_ENSURE_SCHEMA=0
# 生产：=1 时编排器启动即校验 INTERNAL_SIGNING_SECRET（≥32 且非示例值），并禁止 PAYMENT_WEBHOOK_ALLOW_UNSIGNED
# FYV_PRODUCTION=0
# 编排器：每条 HTTP 结束打一行访问日志（含 X-Request-ID、path、status、耗时 ms）
# FYV_HTTP_ACCESS_LOG=0
# ----- 邮箱 / 验证码 / 重置密码（发信在编排器进程内，须给 orchestrator 配下面变量）-----
# 生产（含 FYV_PRODUCTION=1）：须真实 SMTP 发信，并保持下面两项为 0 或未设置（启动期会拒绝开启）
FYV_AUTH_EMAIL_LOG_TOKEN=0
FYV_AUTH_EMAIL_AUTOVERIFY=0
# 本地调试：仅在开发机临时改为只打日志不发信（切勿用于生产或提交到服务器 env）
# FYV_AUTH_EMAIL_LOG_TOKEN=1
# 注册发码限流：每 IP 每分钟次数（<=0 关闭）。默认若 REDIS_URL 可用则用 Redis 计数（多副本共享）；0=仅进程内
# FYV_AUTH_REGISTER_RATE_REDIS=
# FYV_AUTH_REGISTER_SEND_CODE_PER_IP_PER_MIN=10
# 注册密码强度（弱口令 / 含邮箱前缀或用户名）：0=仅上限 128 位与最短 6 位
# FYV_AUTH_STRICT_PASSWORD=1
# 注册验证码仅同步发信（SMTP 成功后才返回 200）；已不再支持后台异步发信，避免界面「已发送」与真实投递不一致
#
# 前端域名（用于邮件里的验证链接、重置密码链接；勿尾斜杠）
# FYV_AUTH_VERIFY_BASE_URL=https://www.prestoai.cn
# 本地联调示例（Web 在 3000、编排器能访问到的公网 URL 填到 FROM 的域的 DNS 更佳）
# FYV_AUTH_VERIFY_BASE_URL=http://localhost:3000
#
# 发件：587 端口固定为「明文 + STARTTLS」；仅 465 为 SMTP_SSL（勿在 587 上设 FYV_SMTP_SSL=1，否则易出现 Connection closed）。
# 必填：主机名非空即视为「已配置 SMTP」；USER/PASSWORD 多数服务商必填。
# 仍报 Connection timed out 时：把 FYV_SMTP_TIMEOUT_SEC 调大（如 90），或改用 465；排查防火墙/容器出网。
#
# FYV_SMTP_TIMEOUT_SEC=90
# 非 465/587 的端口如需隐式 SSL 再设 FYV_SMTP_SSL=1
# FYV_SMTP_SSL=0
# 587 频繁 Connection unexpectedly closed 时默认会自动再试 465 SSL；禁用：FYV_SMTP_FALLBACK_465=0
# EHLO 主机名（可选）：Docker FQDN 异常时可设为发信域，如 mail.example.com
# FYV_SMTP_EHLO_HOSTNAME=
# 排障：FYV_SMTP_DEBUG=1 打印 SMTP 协议对话；仅调试用：FYV_SMTP_TLS_INSECURE=1（跳过证书校验）
#
# FYV_SMTP_HOST=smtp.example.com
# FYV_SMTP_PORT=587
# FYV_SMTP_USER=noreply@example.com
# FYV_SMTP_PASSWORD=your-smtp-password-or-app-password
# FYV_SMTP_FROM=noreply@example.com
#
# 可选：邮件主题（默认已有中文主题，可按品牌修改）
# FYV_SMTP_VERIFY_SUBJECT=完成邮箱验证
# FYV_SMTP_RESET_SUBJECT=重置密码
# FYV_SMTP_REGISTER_OTP_SUBJECT=注册验证码
#
# 忘记密码 token 默认 30 分钟，可调：
# FYV_AUTH_PASSWORD_RESET_TTL_SEC=1800
#
# --- 常见服务商（示例值，请换成自己的账号）---
# Gmail：FYV_SMTP_HOST=smtp.gmail.com  FYV_SMTP_PORT=587  使用「应用专用密码」非网页密码
# Outlook/Hotmail：smtp.office365.com:587
# QQ 邮箱：smtp.qq.com:587，在邮箱设置里开 SMTP 并生成授权码作为 FYV_SMTP_PASSWORD
# 网易 163：smtp.163.com:587，同样使用客户端授权码
# SendGrid 等：按文档使用其 SMTP 主机、端口 587、API Key 作为密码
#
# Docker Compose 编排器已加载本文件副本为 .env.ai-native；改完后需重启 orchestrator 容器/进程。
# 生产投递率建议配置 SPF/DKIM（在域名 DNS 与邮服控制台），FROM 尽量与认证域一致。
# 运维管理员 UUID 名单（逗号分隔），与 FYV_OPS_ADMIN_PHONES 并存
# FYV_OPS_ADMIN_USER_IDS=

# 编排器 PostgreSQL 连接池（默认开；单测或排障可 DB_USE_CONNECTION_POOL=0）
# DB_USE_CONNECTION_POOL=1
# DB_POOL_MIN=1
# DB_POOL_MAX=20
# RETENTION_PAYMENT_WEBHOOK_DAYS=180
# RETENTION_USAGE_EVENTS_DAYS=365
# RETENTION_JOB_EVENTS_DAYS=365
# RETENTION_SUBSCRIPTION_EVENTS_DAYS=730

# ========== MiniMax 模型（可选；不设置则用 app/fyv_shared/config.py 内默认值）==========
MINIMAX_API_KEY=
# MINIMAX_TEXT_MODEL=MiniMax-M2-Preview
# MINIMAX_TTS_MODEL=speech-2.8-turbo
# MINIMAX_VOICE_CLONE_MODEL=speech-02-turbo
# MINIMAX_IMAGE_MODEL=image-01-live

# ========== 文本模型路由（编排器 app/provider_router.py）==========
# minimax | deepseek | qwen；不写 TEXT_PROVIDER 时默认 deepseek（失败回退 MiniMax）；仅文本走 MiniMax 时设置 TEXT_PROVIDER=minimax
# TTS_PROVIDER=minimax
# IMAGE_PROVIDER=minimax
# VOICE_CLONE_PROVIDER=minimax
#
# DeepSeek（TEXT_PROVIDER=deepseek 时必填）
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_TEXT_MODEL=deepseek-chat
#
# 通义千问（TEXT_PROVIDER=qwen）
# QWEN_API_KEY=
# QWEN_BASE_URL=
# QWEN_TEXT_MODEL=qwen-plus

# ========== RAG 向量嵌入（app/fyv_shared/embedding_provider.py）==========
# api | local | hash | auto；api 为 OpenAI 兼容 POST .../embeddings
# RAG_EMBEDDING_PROVIDER=api
# 主端点（常用 MiniMax；可与 MINIMAX_API_KEY 共用，或单独 RAG_EMBEDDING_API_KEY）
# RAG_EMBEDDING_API_URL=https://api.minimax.chat/v1/embeddings
# RAG_EMBEDDING_MODEL=embo-01
# RAG_EMBEDDING_API_KEY=
# RAG_EMBEDDING_TIMEOUT_SEC=25
# local 模式：sentence-transformers
# RAG_EMBEDDING_LOCAL_MODEL=BAAI/bge-small-zh-v1.5
# 主端点失败后是否再试 MiniMax 默认 URL+Key（默认 1；设为 0 关闭）
# RAG_EMBEDDING_MINIMAX_FALLBACK=1
# RAG_EMBEDDING_MINIMAX_FALLBACK_MODEL=embo-01
# DeepSeek 无官方 embedding；便宜向量可填任意 OpenAI 兼容服务（链路上先于 RAG_EMBEDDING_API_URL 尝试）
# RAG_EMBEDDING_OPENAI_COMPAT_BASE=https://api.openai.com/v1
# RAG_EMBEDDING_OPENAI_COMPAT_API_KEY=
# RAG_EMBEDDING_OPENAI_COMPAT_MODEL=text-embedding-3-small

# ========== 笔记分层 RAG / 索引（app/note_rag_service.py）==========
# 0/false/no 关闭「摘要+勾选内向量」，向资料提问回退纯前缀截断
# NOTE_LAYERED_RAG=1
# 单笔记最大切块数（16～256，默认 160）
# NOTE_RAG_MAX_CHUNKS_PER_NOTE=160
# 跨笔记检索：关键词粗排倍数/下限/上限（先缩小候选再算向量，块很多时可降 CPU）
# NOTE_RAG_KEYWORD_PREFILTER_MULT=24
# NOTE_RAG_KEYWORD_PREFILTER_FLOOR=200
# NOTE_RAG_KEYWORD_PREFILTER_MAX=1400
# 播客脚本：Redis 缓存秒数；0=关闭（默认）。仅非流式 on_script_delta 路径生效
# SCRIPT_CACHE_TTL_SEC=900
# TTS 正文多段并行合成上限（过大易触发上游限流；双人/分句均适用）
# TTS_SYNTH_MAX_WORKERS=2

# ========== 参考材料切块与 hybrid RAG（app/rag_core.py）==========
# RAG_CHUNK_CHARS=1100
# RAG_CHUNK_OVERLAP=90
# RAG_HYBRID_VECTOR_WEIGHT=0.55
# RAG_HYBRID_KEYWORD_WEIGHT=0.45

# pydub 需要系统 ffmpeg/ffprobe。本机：brew install ffmpeg。
# 若仍报找不到 ffprobe，可显式指定（或保证 PATH 含 /opt/homebrew/bin）：
# FFPROBE_PATH=/opt/homebrew/bin/ffprobe
# FFMPEG_PATH=/opt/homebrew/bin/ffmpeg

NEXT_PUBLIC_ORCHESTRATOR_URL=http://127.0.0.1:8008
# Next 服务端 BFF 调用编排器（须绝对 URL；勿省略 http://，否则请求会打到 Next 自身 → Not Found）
ORCHESTRATOR_URL=http://127.0.0.1:8008
# 值含空格须加引号；否则 bash source 本文件会报错（如 Native: command not found）
NEXT_PUBLIC_APP_NAME="AI Native Studio"

# 支付回调（编排器）：POST 原始 JSON body；X-Payment-Signature = HMAC-SHA256(secret, body) 十六进制
# 本地联调可设 PAYMENT_WEBHOOK_ALLOW_UNSIGNED=1 跳过验签（勿用于生产）
# PAYMENT_WEBHOOK_SECRET=
# PAYMENT_WEBHOOK_ALLOW_UNSIGNED=1

# 管理员内测模拟订阅收银（编排器 /admin/subscription-checkout）；生产接真实收银后可设为 0
# ADMIN_SIMULATED_CHECKOUT_ENABLED=1

# ========== 支付宝电脑网站支付（alipay.trade.page.pay）==========
# 全部配置齐且 ALIPAY_PAY_ENABLED=1 时：订阅页展示「支付宝扫码支付」、充值区展示「支付宝扫码充值」。
# 应用私钥、支付宝公钥均为 PEM；开放平台「接口加签方式」须选 RSA2（SHA256）。
# ALIPAY_PAY_ENABLED=0
# ALIPAY_APP_ID=2021001234567890
# 应用私钥（工具生成的 PKCS1/PKCS8 PEM 均可）：二选一
# ALIPAY_APP_PRIVATE_KEY_PATH=/path/to/app_private_key.pem
# ALIPAY_APP_PRIVATE_KEY_PEM=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
# 支付宝公钥（开放平台「查看支付宝公钥」复制）：二选一
# ALIPAY_PUBLIC_KEY_PATH=/path/to/alipay_public_key.pem
# ALIPAY_PUBLIC_KEY_PEM=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
# 异步通知：公网 HTTPS，建议走 Next BFF（编排器不直接暴露时）
# ALIPAY_NOTIFY_URL=https://www.prestoai.cn/api/webhooks/alipay
# 同步跳转：用户付完回站点（GET）。若不配置，默认使用 notify 域名的 /subscription
# ALIPAY_RETURN_URL=https://www.prestoai.cn/subscription
# 沙箱联调：ALIPAY_SANDBOX=1（openapi-sandbox.dl.alipaydev.com + 沙箱 APP_ID/密钥）
# 正式收款（生产）：ALIPAY_SANDBOX=0（openapi.alipay.com + 开放平台正式应用与 RSA2 密钥）
# ALIPAY_SANDBOX=0
# 已启用支付宝真实收款时，建议关闭订阅页「模拟钱包充值」接口（默认 1；设为 0 后 POST /wallet-checkout/* 返回 403）
# SIMULATED_WALLET_CHECKOUT_ENABLED=0

# 前端客服邮件（mailto 链接）
# NEXT_PUBLIC_SUPPORT_EMAIL=support@example.com

# ========== 生产部署建议（复制到 .env.ai-native 并取消注释、按需填写）==========
# 标记为类生产环境（安全策略等）
# DEPLOYMENT_ENV=production
# 启动期 DDL/对象存储就绪失败则退出，避免带病运行
# ORCHESTRATOR_STRICT_SCHEMA=1
# 非播客类媒体任务勿占位成功
# MEDIA_WORKER_FAIL_ON_NON_PODCAST=1
# 账号/订阅以 PG 为单一事实源（关闭 JSON 双写）
# FYV_AUTH_UNIFIED_PG=1
# 已用 infra/postgres/init 管理表结构时可关闭运行时 DDL 兜底
# FYV_AUTH_RUNTIME_ENSURE_SCHEMA=0
# 接真实收银后关闭模拟结账
# ADMIN_SIMULATED_CHECKOUT_ENABLED=0
# 公网域名与 HTTPS 下将 NEXT_PUBLIC_ORCHESTRATOR_URL / ORCHESTRATOR_URL 配为经网关可达的地址；
# Docker 全栈部署时 compose 已为 web 注入 ORCHESTRATOR_URL=http://orchestrator:8008，勿覆盖为 127.0.0.1。

# ========== Docker 镜像与离线部署（compose 默认为 Hub 短名，与 docker save/load 一致）==========
# 完整离线打包清单：docs/offline-deploy-bundle.md ；一键生成分发目录：make package-offline-bundle
# 联网机构建全栈并打成单个 docker save：make save-full-stack-tar（业务镜像名 aipodcast-*，标签可设 AIPODCAST_IMAGE_TAG=latest）
# 默认无需配置：postgres:16-alpine、redis:7-alpine、minio/minio:latest、构建用 python:3.12-slim / node:20-alpine
#
# ---------- 离线（推荐）：能访问 Hub 的机器上 save，ECS 上 load ----------
# ECS 多为 amd64；若在 arm64（Apple Silicon）上打包，必须加 --platform，否则 RUN apt-get 会报 exec format error：
#   docker pull --platform linux/amd64 postgres:16-alpine redis:7-alpine minio/minio:latest node:20-alpine
# 若服务器上构建时 apt-get install ffmpeg 失败：在联网机器执行 make build-offline-bases（或 bash scripts/build-offline-base-images.sh），
# 得到 aipodcast/python-ffmpeg:3.12-slim-amd64，再在 .env.ai-native 设置：
#   PYTHON_BASE_IMAGE=aipodcast/python-ffmpeg:3.12-slim-amd64
# 编排器/worker 构建时会检测到已有 ffmpeg 并跳过 apt。打包示例：
#   docker save -o bases-amd64.tar aipodcast/python-ffmpeg:3.12-slim-amd64 postgres:16-alpine redis:7-alpine minio/minio:latest node:20-alpine
#   # ECS: docker load -i bases-amd64.tar
#   # ECS: make up-offline   或   bash scripts/docker-compose-offline.sh up -d --build
# 说明：镜像内 pip install / npm install 仍可能访问 PyPI/npm；若服务器无外网，需在联网机完整 docker compose build 后 docker save 业务镜像，或配置 pip/npm 镜像。
# Web 构建默认已用 npmmirror；海外构建可加：NPM_REGISTRY=https://registry.npmjs.org/
# compose 中 build.pull=false；勿用默认 make up（会启用 BuildKit 仍可能访问 docker.io 解析 FROM）。
#
# ---------- 国内 ACR：在 .env.ai-native 覆盖为完整 registry 地址 ----------
# POSTGRES_IMAGE=registry.cn-hangzhou.aliyuncs.com/<ns>/postgres:16-alpine
# REDIS_IMAGE=registry.cn-hangzhou.aliyuncs.com/<ns>/redis:7-alpine
# MINIO_IMAGE=registry.cn-hangzhou.aliyuncs.com/<ns>/minio:latest
# PYTHON_BASE_IMAGE=registry.cn-hangzhou.aliyuncs.com/<ns>/python:3.12-slim
# NODE_BASE_IMAGE=registry.cn-hangzhou.aliyuncs.com/<ns>/node:20-alpine
# 海外构建且不需 Debian 换源时：USE_APT_MIRROR=0
# 然后：docker login … && docker compose -f docker-compose.ai-native.yml --env-file .env.ai-native pull && docker compose … up -d --build

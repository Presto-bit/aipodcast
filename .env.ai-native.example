# =============================================================================
# AI Native / 播客平台 — 环境变量模板（复制为 .env.ai-native 后按需修改）
# - 行尾「# …」为该项说明；以 # 开头的整行为注释，去掉行首 # 后才会被加载。
# - 含真实密钥的 .env.ai-native 已在 .gitignore，请勿提交仓库。
# - 改后须重启：orchestrator、web、ai-worker、media-worker（视你改动的服务而定）。
# =============================================================================

# ---------- PostgreSQL（编排器、worker、Web BFF 读任务/用户）----------
DB_HOST=127.0.0.1  # 热重载开发：本机起 PG 容器时用 127.0.0.1；Compose 内由环境块覆盖为 postgres
DB_PORT=5432  # 数据库端口
DB_NAME=aipodcast  # 库名，须与 init SQL / migrate 一致
DB_USER=aipodcast  # 连接用户名
DB_PASSWORD=aipodcast  # 连接密码；生产请改为强口令

# ---------- Redis（任务队列 RQ、可选限流/会话）----------
REDIS_URL=redis://127.0.0.1:6379/0  # 编排器入队、worker 出队须指向同一实例；Compose 内常为 redis://redis:6379/0（compose environment 会覆盖本行）
# 勿在 URL 上加 protocol=3：redis-py 会走 RESP3 HELLO，部分代理/兼容 Redis 会直接断连（Connection closed by server）
# REDIS_SOCKET_CONNECT_TIMEOUT=8  # 秒；连接握手超时
# REDIS_DISABLE_CLIENT_SETINFO=1  # 1=不向 Redis 发 CLIENT SETINFO（默认）；部分兼容实现会因此掐断连接，改为 0 可恢复标准 redis-py 行为
# RQ_PREPARE_FOR_WORK=1  # 0=跳过 RQ Worker 启动时的 CLIENT SETNAME（仅当你确认远端不支持该命令时再关）

# ---------- 成片 / 作品元数据（可选）----------
# WORK_RESULT_TITLE_LLM=0  # 默认开启：成片/ TTS / 文稿成功后用 TEXT_PROVIDER 再精炼「我的作品」列表标题；设为 0/false/off 可关闭（略省延迟与模型调用）

# ---------- 对象存储 S3 兼容（MinIO / 阿里云 OSS 等）----------
OBJECT_ENDPOINT=http://127.0.0.1:9000  # API Endpoint；Compose 内常为 http://minio:9000
# OBJECT_PRESIGN_ENDPOINT=https://你的公网域名  # 生成给第三方（如豆包）拉文件的预签名 Host，须与反代/证书一致
OBJECT_REGION=us-east-1  # 区域标识，MinIO 可保留默认
OBJECT_ACCESS_KEY=minioadmin  # Access Key
OBJECT_SECRET_KEY=minioadmin  # Secret Key
OBJECT_BUCKET=aipodcast-artifacts  # 存储桶名；编排器启动会尝试创建
OBJECT_FORCE_PATH_STYLE=1  # MinIO/自建 S3 一般须 1（路径风格）；云厂商按文档

# ---------- 编排器 HTTP ----------
ORCHESTRATOR_PORT=8008  # 编排器监听端口
ORCHESTRATOR_API_TOKEN=local-dev-token  # Web→编排器 BFF 携带的 API Token；生产勿用示例值
INTERNAL_SIGNING_SECRET=local-internal-secret  # 站内签名/联调密钥；FYV_PRODUCTION=1 时须≥32字符且非示例

# ---------- Next.js 前端 / BFF ----------
NEXT_PUBLIC_ORCHESTRATOR_URL=http://127.0.0.1:8008  # 浏览器直连编排器（须含协议）；生产改为公网或网关 URL
# NEXT_PUBLIC_CLIP_NAV_PUBLIC=1  # 1=侧栏与 /clip 对所有已登录用户开放；不设则仅管理员可见（默认）
ORCHESTRATOR_URL=http://127.0.0.1:8008  # Next 服务端请求编排器（须绝对 URL）；Docker Web 容器内勿用 127.0.0.1 指编排器
NEXT_PUBLIC_APP_NAME="AI Native Studio"  # 产品展示名；含空格须加引号
# NEXT_PUBLIC_APP_VERSION=1.2.3  # 可选；发版时打进前端包。不设时 release.sh 默认用 git 短 SHA；docker compose 本地构建默认 development
# NEXT_PUBLIC_APP_BUILD_ID=12345  # 可选；单调递增整数，打进前端包。不设时 release.sh 默认用 git rev-list --count HEAD；用于 DeployVersionSync 避免软刷新命中旧 JS 时把 localStorage 降回旧版本
# NEXT_PUBLIC_SUPPORT_EMAIL=support@example.com  # 页脚客服 mailto

# ---------- 阿里云 CDN（可选：release.sh 成功后自动刷新）----------
# 须在发布机安装 aliyun CLI 并为 AK 授予 CDN 刷新权限（如 AliyunCDNFullAccess 或含 RefreshObjectCaches 的自定义策略）。
# ALIYUN_CDN_REFRESH_ON_RELEASE=1  # 1=发版成功后执行 scripts/aliyun-cdn-refresh.sh；不设或 0 则跳过
# ALIYUN_CDN_REFRESH_URLS="https://www.example.com/,https://www.example.com/admin/"  # 逗号分隔；与控制台「刷新预热」里填的 URL 一致，须含 https://
# ALIYUN_CDN_REFRESH_OBJECT_TYPE=Directory  # Directory=目录刷新（URL 须以 / 结尾）；File=单 URL 文件刷新
# prestoai.cn 示例（仅加速 apex 时只保留 prestoai.cn 两行；同时有 www 时 apex 与 www 都要列，否则未列的一端仍可能旧）：
# ALIYUN_CDN_REFRESH_URLS="https://prestoai.cn/,https://prestoai.cn/admin/,https://www.prestoai.cn/,https://www.prestoai.cn/admin/"
# 仍见旧 chunk 时可临时追加（目录刷新会短时增回源）：https://prestoai.cn/_next/static/,https://www.prestoai.cn/_next/static/
# ALIBABA_CLOUD_ACCESS_KEY_ID=你的AccessKeyId
# ALIBABA_CLOUD_ACCESS_KEY_SECRET=你的AccessKeySecret
# 也可使用 ALIYUN_ACCESS_KEY_ID / ALIYUN_ACCESS_KEY_SECRET 命名（脚本同等支持）

# ---------- 图片代理（Web /api/image-proxy）----------
# IMAGE_PROXY_HOST_SUFFIXES=s3.amazonaws.com,cloudfront.net  # 仅允许这些后缀的主机，防 SSRF；留空则走其它校验逻辑
# IMAGE_PROXY_ALLOW_UNAUTHENTICATED=1  # 本地调封面代理可开；生产勿开

# ---------- 回收站与后台维护 ----------
# TRASH_RETENTION_DAYS=7  # 回收站保留天数
# TRASH_PURGE_INTERVAL_SEC=3600  # 编排器定时清理间隔秒；0=不跑独立循环
# TRASH_PURGE_MAX_ROWS=500  # 每轮清理/剥离 audio_hex 最大行数

# ---------- 编排器队列（RQ）：播客脚本走 ai，合成/导出等走 media ----------
# ORCHESTRATOR_EMBED_RQ_AI_WORKER=1  # 1=编排器进程内嵌消费「ai」队列；0=仅独立 ai-worker 消费
# ORCHESTRATOR_EMBED_RQ_MEDIA_WORKER=1  # 1=进程内嵌消费「media」队列；0=仅独立 media-worker 消费
# 未设置上述变量时：FYV_PRODUCTION 未开启 → 默认内嵌 ai+media（本机只起 uvicorn 也能出队）；FYV_PRODUCTION=1 → 默认关闭内嵌，须起独立 worker。
# docker-compose.ai-native.yml 已对编排器默认设 EMBED=0，由独立 ai-worker/media-worker 消费，避免双消费。

# ORCHESTRATOR_STRICT_SCHEMA=1  # 1=启动期对象存储/DDL 任一失败则进程退出（生产推荐）
# MEDIA_WORKER_FAIL_ON_NON_PODCAST=1  # 1=非播客类 media 任务失败占位（生产避免假成功）

# ---------- 连接池与审计保留（可选）----------
# DB_USE_CONNECTION_POOL=1  # 编排器是否用 psycopg 连接池
# DB_POOL_MIN=1  # 池最小连接
# DB_POOL_MAX=20  # 池最大连接
# RETENTION_PAYMENT_WEBHOOK_DAYS=180  # 支付 webhook 投递记录保留
# RETENTION_USAGE_EVENTS_DAYS=365  # 用量事件保留
# RETENTION_JOB_EVENTS_DAYS=365  # 任务事件保留
# RETENTION_SUBSCRIPTION_EVENTS_DAYS=730  # 订阅事件保留

# ---------- 运行时目录与认证后端（可选，旧版 FYV 路径）----------
# FYV_RUNTIME_DIR=legacy_backend  # 运行时根
# FYV_DATA_DIR=legacy_backend/data  # 数据目录
# FYV_UPLOAD_DIR=legacy_backend/uploads  # 上传目录
# FYV_OUTPUT_DIR=legacy_backend/outputs  # 输出目录
FYV_AUTH_SESSION_BACKEND=redis  # 生产推荐：会话存 Redis（与 REDIS_URL 同一实例；Compose 内由 environment 覆盖为 redis://redis:6379/0）
# FYV_AUTH_UNIFIED_PG=1  # 账号以 PG 为单一事实源
# FYV_AUTH_PG_PRIMARY=1  # PG 为主
# FYV_AUTH_DUAL_WRITE=0  # 关闭双写 JSON
# FYV_AUTH_JSON_BACKUP_READONLY=1  # JSON 仅只读镜像
# FYV_AUTH_ALLOW_JSON_LOGIN=0  # PG 主且库可用时：0（默认）禁止仅凭 users.json 校验密码；=1 仅用于迁移/救急
# FYV_REQUIRE_INVITE=0  # 1=注册须邀请码
# FYV_ADMIN_INVITE_CODE=your-invite  # 邀请码明文
# FYV_AUTH_RUNTIME_ENSURE_SCHEMA=0  # 0=关闭启动期 DDL 兜底（表结构已由 migrate 管理时）

# FYV_PRODUCTION=0  # 1=生产模式：安全强校验、默认关闭内嵌 RQ worker 等；本地纯开发可保持 0
# FYV_HTTP_ACCESS_LOG=0  # 1=每条 HTTP 打访问日志

# ---------- 邮箱 / 注册验证（编排器发信；生产须真实 SMTP）----------
FYV_AUTH_EMAIL_LOG_TOKEN=0  # 1=仅打日志不发信（仅本地调试用）
FYV_AUTH_EMAIL_AUTOVERIFY=0  # 1=自动通过验证（勿用于生产）
# FYV_AUTH_REGISTER_RATE_REDIS=  # 1=注册发码限流用 Redis；空且 REDIS_URL 可用时也会用 Redis
# FYV_AUTH_REGISTER_SEND_CODE_PER_IP_PER_MIN=10  # 每 IP 每分钟发码次数；≤0 关闭
# FYV_AUTH_STRICT_PASSWORD=1  # 1=强密码策略
# FYV_AUTH_VERIFY_BASE_URL=https://www.prestoai.cn  # 邮件内验证/重置链接的站点根（与浏览器访问主域一致），勿尾斜杠
# FYV_AUTH_PASSWORD_RESET_TTL_SEC=1800  # 重置密码 token 有效期秒
# FYV_SMTP_TIMEOUT_SEC=90  # SMTP 超时；超时或 587 不稳定可调大或改用 465
# FYV_SMTP_SSL=0  # 465 隐式 SSL 时可能需 1；587 STARTTLS 一般为 0
# FYV_SMTP_FALLBACK_465=1  # 587 失败时是否自动试 465
# FYV_SMTP_EHLO_HOSTNAME=mail.example.com  # EHLO 主机名（可选）
# FYV_SMTP_DEBUG=0  # 1=打印 SMTP 协议调试
# FYV_SMTP_TLS_INSECURE=0  # 1=跳过 TLS 校验（仅排障）
# FYV_SMTP_HOST=smtp.example.com  # SMTP 主机
# FYV_SMTP_PORT=587  # 端口：587 为 STARTTLS，465 为 SSL
# FYV_SMTP_USER=noreply@example.com  # SMTP 用户名
# FYV_SMTP_PASSWORD=  # SMTP 密码或授权码
# FYV_SMTP_FROM=noreply@example.com  # 发件人地址
# FYV_SMTP_VERIFY_SUBJECT=[Presto] 验证你的邮箱  # 验证邮件主题
# FYV_SMTP_RESET_SUBJECT=[Presto] 找回密码  # 重置邮件主题
# FYV_SMTP_REGISTER_OTP_SUBJECT=[Presto] 注册验证码  # 注册 OTP 主题
# FYV_OPS_ADMIN_USER_IDS=  # 运维管理员 UUID 列表，逗号分隔
# FYV_OPS_ADMIN_PHONES=  # 运维管理员手机号，与 role=admin 叠加

# ---------- 启动时引导管理员（编排器 lifespan 内调用；PG 单一事实源）----------
# FYV_BOOTSTRAP_ADMIN_ENABLED=0  # 1=启用：不存在则创建 admin；已存在则升 role=admin + max 年付
# FYV_BOOTSTRAP_ADMIN_PHONE=1xxxxxxxxxx
# FYV_BOOTSTRAP_ADMIN_PASSWORD=  # 至少 6 位；成功后请关 ENABLED 并换强口令
# FYV_BOOTSTRAP_ADMIN_FORCE_PASSWORD=0  # 1=已存在用户时也重置为上一行密码

# ---------- MiniMax（脚本/TTS/克隆/文生图等；可与路由组合使用）----------
MINIMAX_API_KEY=  # 平台接口密钥；留空则依赖 MiniMax 的能力不可用（若 TEXT_PROVIDER 非 minimax 仍可做 TTS）
# MINIMAX_API_BASE=https://api.minimax.chat/v1  # API 根路径；域名变更时可覆写
# MINIMAX_TEXT_MODEL=MiniMax-M2-Preview  # 文本模型
# MINIMAX_TTS_MODEL=speech-2.8-turbo  # 语音合成模型
# MINIMAX_VOICE_CLONE_MODEL=speech-02-turbo  # 克隆接口模型
# MINIMAX_IMAGE_MODEL=image-01-live  # 文生图模型；带 -live 时才支持 style 画风参数
# MINIMAX_IMAGE_STYLE_TYPE=元气  # 画风：仅允许 漫画|元气|中世纪|水彩；勿填「插画」
# MINIMAX_IMAGE_STYLE_WEIGHT=0.38  # 画风权重 (0,1]
# MINIMAX_COVER_STYLE_TYPE=  # 与 MINIMAX_IMAGE_STYLE_TYPE 等价别名（二选一）
# AIPODCAST_IMAGE_STYLE_TYPE=  # 同上别名

# ---------- 模型路由（编排器 provider_router）----------
# TEXT_PROVIDER=deepseek  # 文稿大模型：minimax | deepseek | qwen；默认 deepseek（失败可回退）
# TTS_PROVIDER=minimax  # 语音：minimax 等
# IMAGE_PROVIDER=minimax  # 封面/配图：minimax | qwen（qwen 须配 QWEN_*）
# VOICE_CLONE_PROVIDER=minimax  # 克隆：minimax 等
# DEEPSEEK_API_KEY=  # TEXT_PROVIDER=deepseek 时必填
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1  # DeepSeek API 根
# DEEPSEEK_TEXT_MODEL=deepseek-chat  # DeepSeek 模型名
# QWEN_API_KEY=  # TEXT_PROVIDER=qwen 或图走通义时
# QWEN_BASE_URL=  # 通义 OpenAPI 根
# QWEN_TEXT_MODEL=qwen-plus  # 通义文本模型
# QWEN_IMAGE_URL=  # IMAGE_PROVIDER=qwen 时图生 HTTP 端点
# QWEN_IMAGE_MODEL=wanx-v1  # 通义图像模型

# ---------- RAG 向量嵌入（笔记/参考材料）----------
# RAG_EMBEDDING_PROVIDER=api  # api | local | hash | auto
# RAG_EMBEDDING_API_URL=https://api.minimax.chat/v1/embeddings  # OpenAI 兼容 embeddings URL
# RAG_EMBEDDING_MODEL=embo-01  # 嵌入模型名
# RAG_EMBEDDING_API_KEY=  # 可空则回退 MINIMAX_API_KEY
# RAG_EMBEDDING_TIMEOUT_SEC=25  # 请求超时秒
# RAG_EMBEDDING_LOCAL_MODEL=BAAI/bge-small-zh-v1.5  # local 模式模型 id
# RAG_EMBEDDING_MINIMAX_FALLBACK=1  # 主链失败是否试 MiniMax 默认端点
# RAG_EMBEDDING_MINIMAX_FALLBACK_MODEL=embo-01  # 回退模型
# RAG_EMBEDDING_OPENAI_COMPAT_BASE=https://api.openai.com/v1  # 备用 OpenAI 兼容基址
# RAG_EMBEDDING_OPENAI_COMPAT_API_KEY=  # 备用 Key
# RAG_EMBEDDING_OPENAI_COMPAT_MODEL=text-embedding-3-small  # 备用模型

# ---------- 笔记分层 RAG / 播客侧参数（可选）----------
# NOTE_LAYERED_RAG=1  # 0=关闭摘要+向量，仅截断
# NOTE_RAG_MAX_CHUNKS_PER_NOTE=160  # 单笔记最大块数
# NOTE_RAG_KEYWORD_PREFILTER_MULT=24  # 关键词粗排倍数
# NOTE_RAG_KEYWORD_PREFILTER_FLOOR=200  # 粗排下限
# NOTE_RAG_KEYWORD_PREFILTER_MAX=1400  # 粗排上限
# SCRIPT_CACHE_TTL_SEC=900  # 脚本缓存秒数；0=关
# TTS_SYNTH_MAX_WORKERS=2  # TTS 并行段数上限

# ---------- 参考材料 hybrid RAG（可选）----------
# RAG_CHUNK_CHARS=1100  # 切块字符数
# RAG_CHUNK_OVERLAP=90  # 块重叠
# RAG_HYBRID_VECTOR_WEIGHT=0.55  # 向量混合权重
# RAG_HYBRID_KEYWORD_WEIGHT=0.45  # 关键词混合权重

# ---------- 豆包 / 火山 剪辑转写（OpenSpeech 异步 submit+query）----------
# VOLCENGINE_SPEECH_API_KEY=  # （A）新控制台 API Key，作 X-Api-Key
# VOLCENGINE_OPENSPEECH_API_KEY=  # 与上一项别名二选一
# VOLCENGINE_SPEECH_APP_KEY=  # （B）旧控制台 AppId
# VOLCENGINE_SPEECH_ACCESS_KEY=  # （B）Access Token；勿把 Secret Key 填进 API_KEY
# VOLCENGINE_SPEECH_ACCESS_TOKEN=  # 与 ACCESS_KEY 别名
# VOLCENGINE_SPEECH_UID=  # 请求体 user.uid，默认可与 app key 同
# VOLCENGINE_SEED_ASR_RESOURCE_ID=volc.seedasr.auc  # 资源 id
# VOLCENGINE_SPEECH_SUBMIT_URL=https://openspeech.bytedance.com/api/v3/auc/bigmodel/submit  # 提交任务 URL
# VOLCENGINE_SPEECH_QUERY_URL=https://openspeech.bytedance.com/api/v3/auc/bigmodel/query  # 轮询 URL
# VOLCENGINE_SEED_POLL_INTERVAL_SEC=2  # 轮询间隔秒
# VOLCENGINE_SEED_POLL_MAX_SEC=7200  # 最长轮询秒
# VOLCENGINE_SEED_AUDIO_FORMAT=mp3  # 预签名无扩展名时强制音频类型
# CLIP_VOLC_SEED_MAX_INLINE_BYTES=83886080  # 小于此字节则内联 Base64 提交，不依赖公网拉预签名
# CLIP_AUDIO_PRESIGNED_EXPIRES_SEC=172800  # 预签名给豆包拉音频的有效期秒
# CLIP_MAX_UPLOAD_BYTES=209715200  # 剪辑上传单文件上限字节
# CLIP_EXPORT_MERGE_GAP_MS=120  # ffmpeg 导出词间合并间隙毫秒
# CLIP_LLM_SUGGESTION_MAX_WORDS=900  # 剪辑建议 TSV 最大词行
# CLIP_LLM_SUGGESTION_CHAR_BUDGET=14000  # 剪辑建议总字符预算

# ---------- ffmpeg（pydub/媒体处理）----------
# FFPROBE_PATH=/opt/homebrew/bin/ffprobe  # 显式 ffprobe 路径（可选）
# FFMPEG_PATH=/opt/homebrew/bin/ffmpeg  # 显式 ffmpeg 路径（可选）

# ---------- 支付 / 内测（编排器）----------
# PAYMENT_WEBHOOK_SECRET=  # 通用支付回调 HMAC 密钥（JSON 类 webhook）；生产须配置
# PAYMENT_WEBHOOK_ALLOW_UNSIGNED=1  # 1=本地跳过签名校验（勿用于生产）
# ADMIN_SIMULATED_CHECKOUT_ENABLED=0  # 接真实订阅支付后保持 0；本地可 1
# SIMULATED_WALLET_CHECKOUT_ENABLED=0  # 接支付宝真收款后保持 0，避免展示内测模拟充值

# ---------- 支付宝真实收款（alipay.trade.page.pay / 电脑网站支付）----------
# 以下全部配置正确且 ALIPAY_PAY_ENABLED=1 时，编排器对外价目会标记 alipay_page 可用，前端充值弹窗可调起正式网关。
# 开放平台「应用网关」或接口异步通知地址 必须与 ALIPAY_NOTIFY_URL 完全一致（含 https、是否 www、路径）。
# 公网入口为 Next：`POST https://<站点>/api/webhooks/alipay` → BFF 转发编排器 `POST /api/v1/webhooks/alipay`（勿将编排器 8008 直连公网）。
# ALIPAY_PAY_ENABLED=1
# ALIPAY_SANDBOX=0  # 0=正式环境 openapi.alipay.com；1=沙箱 openapi-sandbox.dl.alipaydev.com（仅联调）
# ALIPAY_APP_ID=
# ALIPAY_APP_PRIVATE_KEY_PATH=secrets/app_private_key.pem  # 或 ALIPAY_APP_PRIVATE_KEY_PEM=（Docker 下路径相对编排器工作目录 /app）
# ALIPAY_PUBLIC_KEY_PATH=secrets/alipay_public_key.pem  # 须为开放平台「支付宝公钥」，非应用公钥
# ALIPAY_PUBLIC_KEY_PEM=
# 生产示例（主域带 www 时与浏览器访问一致；若只用 apex 则改为 https://prestoai.cn/...）
# ALIPAY_NOTIFY_URL=https://www.prestoai.cn/api/webhooks/alipay
# ALIPAY_RETURN_URL=https://www.prestoai.cn/subscription  # 可不设：未配置时由 NOTIFY_URL 推导为同主机 /subscription

# ---------- 生产类开关（按需取消注释）----------
# DEPLOYMENT_ENV=production  # 标记类生产（部分策略）
# COOKIE_SECURE=1  # HTTPS 站点须 1，以便浏览器带 Secure Cookie
# COOKIE_DOMAIN=.prestoai.cn  # apex 与 www 等同根子域共享 fym_session 时设置（须「点 + 根域」）

# ---------- Docker 镜像与离线构建（compose 默认 Hub 短名）----------
# 详见 docs/offline-deploy-bundle.md；打包：make package-offline-bundle / make save-full-stack-tar
# POSTGRES_IMAGE=postgres:16-alpine  # 覆盖 Postgres 镜像
# REDIS_IMAGE=redis:7-alpine  # 覆盖 Redis 镜像
# MINIO_IMAGE=minio/minio:latest  # 覆盖 MinIO 镜像
# PYTHON_BASE_IMAGE=python:3.12-slim  # 业务镜像构建用 Python 基础镜像
# Web 构建用 Node 基础镜像（默认 docker.io；国内 ECS 常因 Hub 限流/元数据异常失败，见下）
# NODE_BASE_IMAGE=node:20-alpine
# 国内可改用镜像加速拉取（择一；须与 docker-compose 中 web.build.args 一致）：
# NODE_BASE_IMAGE=docker.m.daocloud.io/library/node:20-alpine
# 亦可配置宿主机 /etc/docker/daemon.json 的 registry-mirrors 后仍用 node:20-alpine
# AIPODCAST_IMAGE_TAG=latest  # 业务镜像 tag
# USE_APT_MIRROR=1  # 1=构建时优先国内 apt 镜像
# NPM_REGISTRY=https://registry.npmmirror.com  # npm 源；海外可改 registry.npmjs.org
# COMPOSE_BUILD_PULL=1  # release.sh：docker compose build 是否加 --pull（默认 1，刷新各 Dockerfile 的 FROM；0 可省时间与带宽；离线发版请设 0）
# DOCKER_BUILD_NO_CACHE=1  # release.sh：构建禁用层缓存（极慢，仅依赖/层缓存异常排障时用）
